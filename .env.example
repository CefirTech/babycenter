# ============================================================
# BABYCENTER — Variables d'environnement (exemple)
# ============================================================
# Copier ce fichier en .env.local pour le développement local.
# NE JAMAIS committer .env ou .env.local dans le dépôt git.
# ============================================================

# --- Supabase (frontend public — clé anon uniquement) -------
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-public-key>
VITE_SUPABASE_PROJECT_ID=<project-id>

# --- Optionnel : Sentry (suivi d'erreurs production) --------
# VITE_SENTRY_DSN=https://<key>@sentry.io/<project>

# --- Optionnel : Analytics ----------------------------------
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# SECRETS CÔTÉ SERVEUR (Edge Functions — jamais dans le front)
# Ces variables sont injectées automatiquement dans Supabase.
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
# SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_URL=https://<project-id>.supabase.co
